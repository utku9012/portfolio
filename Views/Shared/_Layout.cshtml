<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "Personal portfolio website with experience, projects, education, skills, and certifications.")" />
    <meta property="og:title" content="@ViewData["Title"] - Portfolio" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "Personal portfolio website with experience, projects, education, skills, and certifications.")" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/profile.jpg" />
    <title>@ViewData["Title"] - Portfolio</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@ViewData["BodyClass"]">
    <div class="global-controls" aria-label="Display controls">
        <button class="control-button" type="button" data-theme-toggle aria-label="Toggle dark theme" title="Toggle theme">
            <i class="fas fa-moon" aria-hidden="true"></i>
        </button>
        <button class="control-button language-button" type="button" data-language-toggle aria-label="Turkish language" title="Turkish">
            TR
        </button>
    </div>
    <main role="main">
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
